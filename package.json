{
  "name": "pretext-tools-monorepo",
  "displayName": "PreTeXt-tools-monorepo",
  "description": "Monorepo for PreTeXt tools",
  "version": "0.0.1",
  "license": "See license in LICENSE",
  "publisher": "oscarlevin",
  "repository": "https://github.com/oscarlevin/pretext-tools",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "latex-pretext:use-local-unified-latex": "node ./scripts/install-unified-latex-from-source.cjs ../unified-latex",
    "playground:dev": "npm run dev -w @pretextbook/playground",
    "build": "npm run build:deps && npm run build -w pretext-tools",
    "build:deps": "npm run build:utils && npm run build:libs",
    "build:utils": "npm run build -w @pretextbook/ptxast && npm run build -w @pretextbook/remark-pretext && npm run build -w @pretextbook/ptxast-util-to-mdast",
    "build:libs": "npm run build -w @pretextbook/format && npm run build -w @pretextbook/latex-pretext && npm run refresh-schema -w @pretextbook/completions && npm run build -w @pretextbook/completions && npm run build:lib -w @pretextbook/visual-editor",
    "build:dev": "npm run build:deps && npm run build:dev -w pretext-tools",
    "build:packages": "npm run build:deps",
    "watch": "npm run watch -w pretext-tools",
    "refresh:schemas": "node ./scripts/getSchemas.js && node ./packages/completions/scripts/generate-default-schema.mjs && npm run generate-types -w @pretextbook/ptxast",
    "check:schema-generated": "node ./scripts/check-schema-generated.mjs",
    "lint": "npm run lint -w prettier-plugin-pretext && npm run lint -w @pretextbook/visual-editor && npm run lint -w pretext-tools",
    "test": "npm run test -w @pretextbook/completions && npm run test -w prettier-plugin-pretext && npm run test:reliability",
    "test:reliability": "npm exec vitest run packages/remark-pretext/src/lib/remark-pretext.spec.ts packages/ptxast-util-to-mdast/src/lib/ptxast-util-to-mdast.spec.ts packages/latex-pretext/src/lib/latex-pretext.spec.ts",
    "pretest": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "ajv": "^8.18.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "mocha": "^11.3.0",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.9",
    "remark-directive": "^4.0.0",
    "replace-json-property": "^1.9.0",
    "sass-embedded": "^1.97.3",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@lezer/xml": "^1.0.6",
    "@tiptap/extension-hard-break": "^3.20.1",
    "@tiptap/extension-text": "^3.20.1",
    "@unified-latex/unified-latex-to-hast": "^1.8.4",
    "@unified-latex/unified-latex-util-arguments": "^1.8.4",
    "@unified-latex/unified-latex-util-html-like": "^1.8.4",
    "@unified-latex/unified-latex-util-parse": "^1.8.4",
    "deepmerge": "^4.3.1",
    "esbuild-node-externals": "^1.20.1",
    "frankenmarkup": "github:davidfarmer/FrankenMarkUp",
    "fs.promises.exists": "^1.1.4",
    "glob": "^13.0.6",
    "md2ptx": "github:skiadas/md2ptx",
    "mdast-util-from-markdown": "^2.0.3",
    "prettier": "~3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "rehype-stringify": "^10.0.1",
    "saxes": "^6.0.0",
    "time-stamp": "^2.2.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0",
    "xast-util-from-xml": "^4.0.0",
    "xast-util-to-string": "^3.0.0",
    "xast-util-to-xml": "^4.0.0",
    "xml2js": "^0.6.2"
  },
  "prettier": {
    "tabWidth": 2
  }
}

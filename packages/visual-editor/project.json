{
  "name": "@pretextbook/visual-editor",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/visual-editor/src",
  "targets": {
    "build:lib": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/visual-editor",
        "command": "npm run build:lib"
      },
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": ["vite"]
        }
      ],
      "outputs": ["{workspaceRoot}/packages/visual-editor/dist"],
      "metadata": {
        "technologies": ["vite", "react", "tiptap"],
        "description": "Builds the visual-editor as a reusable library"
      }
    },
    "build:all": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:lib", "vite:build"],
      "options": {
        "cwd": "packages/visual-editor",
        "command": "echo 'All builds complete'"
      },
      "cache": false,
      "metadata": {
        "description": "Builds both library and webview versions"
      }
    }
  }
}

{
  "name": "@pretextbook/ptxast-util-to-mdast",
  "version": "0.0.1",
  "description": "Convert ptxast to mdast (markdown AST) and markdown strings",
  "author": "Oscar Levin",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pretextbook/pretext-tools.git",
    "directory": "packages/ptxast-util-to-mdast"
  },
  "bugs": {
    "url": "https://github.com/pretextbook/pretext-tools/issues"
  },
  "homepage": "https://github.com/pretextbook/pretext-tools/packages/ptxast-util-to-mdast#readme",
  "private": false,
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "*.js",
    "*.cjs",
    "*.d.ts",
    "*.d.cts",
    "lib"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@pretextbook/ptxast": "^0.0.1",
    "@types/mdast": "^4.0.0",
    "mdast-util-directive": "^3.0.0",
    "mdast-util-math": "^3.0.0",
    "mdast-util-to-markdown": "^2.0.0",
    "xast": "^0.1.334",
    "xast-util-from-xml": "^4.0.0",
    "xast-util-to-xml": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

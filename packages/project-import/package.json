{
  "name": "@pretextbook/project-import",
  "version": "0.0.1",
  "description": "Shared import helpers for converting LaTeX/Markdown/PreTeXt into PreTeXt for VS Code and web apps",
  "author": "Oscar Levin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PreTeXtBook/pretext-tools.git"
  },
  "bugs": {
    "url": "https://github.com/PreTeXtBook/pretext-tools/issues"
  },
  "homepage": "https://github.com/PreTeXtBook/pretext-tools/tree/main/packages/project-import",
  "private": false,
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.js"
    }
  },
  "sideEffects": false,
  "files": [
    "*.js",
    "*.cjs",
    "*.d.ts",
    "*.d.cts",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@pretextbook/format": "*",
    "@pretextbook/latex-pretext": "*",
    "@pretextbook/remark-pretext": "*",
    "jszip": "^3.10.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

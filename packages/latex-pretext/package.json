{
  "name": "@pretextbook/latex-pretext",
  "version": "0.0.8",
  "description": "Tools for working with PreTeXt documents in LaTeX format",
  "author": "Oscar Levin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PreTeXtBook/pretext-tools.git"
  },
  "bugs": {
    "url": "https://github.com/PreTeXtBook/pretext-tools/issues"
  },
  "homepage": "https://github.com/PreTeXtBook/pretext-tools/packages/latex-pretext#readme",
  "private": false,
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "*.js",
    "*.cjs",
    "*.d.ts",
    "*.d.cts",
    "lib"
  ],
  "scripts": {
    "dev": "npm exec vite playground",
    "dev:build": "npm exec vite -- build playground --outDir ../../../dist/packages/latex-pretext/playground"
  },
  "dependencies": {
    "@unified-latex/unified-latex-to-pretext": "github:pretextplus/unified-latex#release/unified-latex-to-pretext",
    "@unified-latex/unified-latex-util-parse": "github:pretextplus/unified-latex#release/unified-latex-util-parse",
    "@unified-latex/unified-latex-types": "github:pretextplus/unified-latex#release/unified-latex-types",
    "tslib": "^2.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

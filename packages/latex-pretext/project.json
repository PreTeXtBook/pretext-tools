{
  "name": "@pretextbook/latex-pretext",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/latex-pretext/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "playground": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/latex-pretext",
        "command": "npm run dev"
      },
      "isBackground": true,
      "cache": false,
      "metadata": {
        "description": "Runs a local LaTeX to PreTeXt playground for development"
      }
    },
    "playground:build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/latex-pretext",
        "command": "npm run dev:build"
      },
      "outputs": ["{workspaceRoot}/dist/packages/latex-pretext/playground"],
      "cache": true,
      "inputs": ["default", "^default"],
      "metadata": {
        "description": "Builds the latex-pretext development playground"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/latex-pretext",
        "command": "tsc --noEmit -p tsconfig.lib.json"
      },
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{workspaceRoot}/dist/packages/latex-pretext"],
      "options": {
        "outputPath": "dist/packages/latex-pretext"
      },
      "cache": true,
      "dependsOn": ["^build"]
    }
  }
}

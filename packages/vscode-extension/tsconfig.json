{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "noEmit": true,
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src/webview",
    "*.config.mts",
    "*.config.ts"
  ],
  "references": [
    {
      "path": "../remark-pretext"
    },
    {
      "path": "../ptxast-util-to-xml"
    },
    {
      "path": "../ptxast-util-from-xml"
    },
    {
      "path": "../ptxast"
    },
    {
      "path": "../format"
    },
    {
      "path": "./tsconfig.webview.json"
    }
  ]
}

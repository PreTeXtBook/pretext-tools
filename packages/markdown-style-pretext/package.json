{
  "name": "@pretextbook/markdown-style-pretext",
  "version": "0.0.1",
  "description": "Editor intelligence (completions + validation) for Markdown-style PreTeXt documents",
  "author": "Oscar Levin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PreTeXtBook/pretext-tools.git"
  },
  "bugs": {
    "url": "https://github.com/PreTeXtBook/pretext-tools/issues"
  },
  "homepage": "https://github.com/PreTeXtBook/pretext-tools/tree/main/packages/markdown-style-pretext",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "typecheck": "tsc --build --emitDeclarationOnly",
    "test": "vitest run"
  },
  "dependencies": {
    "@pretextbook/latex-style-pretext": "^0.0.1",
    "vscode-languageserver-types": "^3.17.5"
  },
  "devDependencies": {
    "@pretextbook/remark-pretext": "^0.0.11"
  },
  "publishConfig": {
    "access": "public"
  }
}
